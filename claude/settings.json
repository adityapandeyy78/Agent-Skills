{
  "permissions": {
    "allow": [
      "Bash(node -e ':*)",
      "Bash(grep -E \"\\\\.\\(tsx?|jsx?\\)$\")",
      "Bash(grep -E \"\\\\.\\(tsx|ts|jsx|js\\)$\")",
      "Bash(npm start *)",
      "Bash(sleep 3 && tail -50 /tmp/dev-server.log | grep -E \"\\(error|warn|compiled|success\\)\" | head -10)",
      "Read(//private/tmp/**)"
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    }
  },
  "effortLevel": "medium",
  "theme": "dark",
  "tui": "fullscreen"
}
